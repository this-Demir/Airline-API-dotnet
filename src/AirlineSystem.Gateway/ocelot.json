{
  "Routes": [
    {
      "SwaggerKey": "airline-api",
      "UpstreamPathTemplate": "/api/v1/flights/search",
      "UpstreamHttpMethod": [ "GET" ],
      "DownstreamPathTemplate": "/api/v1/flights/search",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "backend-api", "Port": 8080 }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "1d",
        "PeriodTimespan": 86400,
        "Limit": 3
      }
    },
    {
      "SwaggerKey": "airline-api",
      "UpstreamPathTemplate": "/api/v1/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH" ],
      "DownstreamPathTemplate": "/api/v1/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "backend-api", "Port": 8080 }
      ],
      "RateLimitOptions": {
        "EnableRateLimiting": false
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000",
    "RateLimitOptions": {
      "ClientIdHeader": "ClientId",
      "DisableRateLimitHeaders": false,
      "QuotaExceededMessage": "Too many requests. Please try again later.",
      "HttpStatusCode": 429
    }
  },
  "SwaggerEndPoints": [
    {
      "Key": "airline-api",
      "Config": [
        {
          "Name": "Airline Ticketing API",
          "Version": "v1",
          "Url": "http://backend-api:8080/swagger/v1/swagger.json"
        }
      ]
    }
  ]
}
